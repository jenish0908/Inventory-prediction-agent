# ─────────────────────────────────────────────────────────────────
#  HOW TO GET YOUR FREE GROQ API KEY  (no credit card, 2 minutes)
#  1. Go to https://console.groq.com
#  2. Sign up with email or Google account
#  3. Click "API Keys" in the left sidebar
#  4. Click "Create API Key", give it a name, click "Submit"
#  5. Copy the key (starts with gsk_...) and paste it below
#  Free tier: 30 requests/min, 14,400 requests/day — plenty for this project
# ─────────────────────────────────────────────────────────────────

GROQ_API_KEY=gsk_your_key_here

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/inventory_db
REDIS_URL=redis://localhost:6379/0
APP_ENV=development

# MCP server URLs (used by the FastAPI app to reach MCP services)
# In Docker these are overridden to http://inventory-mcp:8001 etc.
INVENTORY_MCP_URL=http://localhost:8001
SUPPLIER_MCP_URL=http://localhost:8002
